{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "es2022"
    ],
    "types": ["node"],
    "module": "NodeNext",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "pretty": true,
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "moduleResolution": "nodenext",
  },
  "include": [
    "src/**/*"
  ]
}